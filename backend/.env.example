# Copy this file to .env and fill in your values. Never commit .env or your token.

# Vanilla live search (maropost.vanillastaging.com)
SEARCH_SOURCE=vanilla
SEARCH_API_BASE_URL=https://maropost.vanillastaging.com
SEARCH_API_KEY=paste_your_vanilla_access_token_here

# Optional: base URL for "Open Live Article" links (defaults to above if not set)
# ARTICLE_BASE_URL=https://maropost.vanillastaging.com
